# ──────────────────────────────────────────
#  Wú · The Book of Changes — Environment Variables
#  Copy this file to .env.local and fill in your values
#  NEVER commit .env.local to git
# ──────────────────────────────────────────

# Creem API Key (from Creem dashboard → Developers)
CREEM_API_KEY=ck_live_YOUR_KEY_HERE

# Creem Webhook Secret (from Creem dashboard → Webhooks)
CREEM_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET_HERE

# Creem Product ID (create a $3.99 one-time product in Creem dashboard → Products)
CREEM_PRODUCT_ID=prod_YOUR_PRODUCT_ID_HERE
NEXT_PUBLIC_CREEM_PRODUCT_ID=prod_YOUR_PRODUCT_ID_HERE

# DeepSeek API Key (from platform.deepseek.com → API Keys)
DEEPSEEK_API_KEY=sk-YOUR_DEEPSEEK_KEY_HERE

# Your site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://your-domain.com
