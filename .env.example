# ──────────────────────────────────────────
#  Wú · The Book of Changes — Environment Variables
#  Copy this file to .env.local and fill in your values
#  NEVER commit .env.local to git
# ──────────────────────────────────────────

# Lemon Squeezy API Key (Settings → API → Create API Key)
LEMONSQUEEZY_API_KEY=eyJ...YOUR_KEY_HERE

# Lemon Squeezy Store ID (Settings → Store → copy the ID from the URL)
LEMONSQUEEZY_STORE_ID=12345

# Lemon Squeezy Variant ID (Products → your product → click variant → copy ID from URL)
LEMONSQUEEZY_VARIANT_ID=67890

# Lemon Squeezy Webhook Secret (Settings → Webhooks → create webhook → copy secret)
LEMONSQUEEZY_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET_HERE

# DeepSeek API Key (platform.deepseek.com → API Keys)
DEEPSEEK_API_KEY=sk-YOUR_DEEPSEEK_KEY_HERE

# Your site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://your-domain.com
